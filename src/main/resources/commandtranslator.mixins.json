{
  "required": true,
  "minVersion": "0.8",
  "package": "com.wishtoday.ts.commandtranslator.mixin",
  "compatibilityLevel": "JAVA_21",
  "mixins": [
    "MinecraftServerMixin",
    "Accessor.ServerCommandSourceAccessor",
    "Accessor.CommandFunction.ExpandedMacroAccessor",
    "CommandBlockImpl.CB_ChunkSerializerMixin",
    "FunctionImpl.FC_CommandFunctionManagerMixin",
    "FunctionImpl.FC_FunctionLoaderMixin",
    "TextNodeParserImpl.CommandDispatcherMixin",
    "TextNodeParserImpl.LiteralArgumentBuilderMixin"
  ],
  "injectors": {
    "defaultRequire": 1
  },
  "overwrites": {
    "requireAnnotations": true
  },
  "plugin": "com.wishtoday.ts.commandtranslator.MixinExtension"
}
